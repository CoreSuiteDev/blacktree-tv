// ============================================================
// rbac.prisma
// Models: Role, Permission, RolePermission, UserRoleMapping
// Handles: fine-grained role-based access control
// ============================================================

model Role {
  id String @id @default(cuid())

  name        String  @unique // e.g. "admin", "moderator", "user"
  description String?

  permissions RolePermission[]
  users       UserRoleMapping[]
}

// ------------------------------------------------------------
// Permission
// Granular permission keys, e.g. "chat:delete", "user:ban"
// ------------------------------------------------------------
model Permission {
  id String @id @default(cuid())

  key         String  @unique // e.g. "user:ban", "content:publish"
  description String?

  roles RolePermission[]
}

// ------------------------------------------------------------
// RolePermission — join table (Role <-> Permission)
// ------------------------------------------------------------
model RolePermission {
  id String @id @default(cuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ------------------------------------------------------------
// UserRoleMapping — join table (User <-> Role)
// A user can hold multiple roles (e.g. admin + moderator)
// ------------------------------------------------------------
model UserRoleMapping {
  id String @id @default(cuid())

  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}
