// ============================================================
// chat.prisma
// Models: LiveChat, ChatBan
// ============================================================

model LiveChat {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  message String

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

// ------------------------------------------------------------
// ChatBan
// Tracks who banned whom, with type and optional expiry.
// ------------------------------------------------------------
model ChatBan {
  id String @id @default(cuid())

  // The user being banned
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The moderator/admin who issued the ban
  bannedById String
  bannedBy   User   @relation("BannedBy", fields: [bannedById], references: [id])

  type ChatBanType

  reason String?

  // null = permanent ban
  expiresAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([bannedById])
  @@index([isActive])
  @@index([expiresAt])
}
