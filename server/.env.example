# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_PREFETCH=10

# Scheduler (Cron Jobs)
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production-minimum-32-characters
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration
# For Gmail in development
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=PrepExcellence <noreply@prepexcellence.com>
EMAIL_USE_SES=false

# For AWS SES in production
# EMAIL_USE_SES=true
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-ses-access-key
# AWS_SECRET_ACCESS_KEY=your-ses-secret-key

# AWS S3 (Optional - deprecated, use MinIO instead)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=prepexcellence
MINIO_REGION=us-east-1

# Socket.IO
SOCKET_CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
