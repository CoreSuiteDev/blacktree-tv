model Actor {
  id String @id @default(cuid())

  name String
  slug String @unique

  biography String? @db.Text

  birthDate DateTime?

  profileImage String?

  createdAt DateTime @default(now())

  castIn     MovieCast[]
  interviews ActorInterview[]

  @@index([slug])
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  email         String
  emailVerified Boolean @default(false)
  image         String?

  sessions Session[]
  accounts Account[]

  role UserRole @default(USER)

  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  profile UserProfile?

  subscription   Subscription[]
  paymentHistory PaymentHistory[]

  chatBans      ChatBan[]
  liveChat      LiveChat[]
  bannedByUsers ChatBan[]  @relation("BannedBy")

  moderationLogs ModerationLog[] @relation("ModeratorLogs")
  targetUserLogs ModerationLog[] @relation("TargetUserLogs")

  roleMappings UserRoleMapping[]

  subscribed Subscriber[]

  watchHistory WatchHistory[]
  watchlist    Watchlist[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expiresAt DateTime

  token String

  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId  String
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken  String?
  refreshToken String?
  idToken      String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  scope    String?
  password String?

  @@index([userId])
  @@map("account")
}

model Verification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identifier String
  value      String
  expiresAt  DateTime

  @@index([identifier])
  @@map("verification")
}

model Jwks {
  id String @id @default(cuid())

  publicKey  String
  privateKey String

  createdAt DateTime @default(now())

  @@map("jwks")
}

model LiveChat {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  message String

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model ChatBan {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bannedById String
  bannedBy   User   @relation("BannedBy", fields: [bannedById], references: [id])

  type ChatBanType

  reason String?

  expiresAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([bannedById])
  @@index([isActive])
  @@index([expiresAt])
}

enum AuthProvider {
  credential
  google
  apple
}

enum UserRole {
  ADMIN
  MODERATOR
  USER
}

enum SubscriptionType {
  STANDARD
  PREMIUM
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  SSLCOMMERZ
  BKASH
  NAGAD
  ROCKET
}

enum ChatBanType {
  TIMEOUT
  TEMP_BAN
  PERMANENT
}

enum ModerationAction {
  USER_BANNED
  USER_UNBANNED
  CHAT_MESSAGE_DELETED
  CHAT_USER_MUTED
  SUBSCRIPTION_CANCELLED
  MOVIE_CREATED
  MOVIE_UPDATED
  MOVIE_DELETED
  USER_ROLE_UPDATED
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  PENDING
}

enum MediaAssetType {
  THUMBNAIL
  POSTER
  BANNER
  VIDEO
  TRAILER
  SUBTITLE
}

enum CastRoleType {
  ACTOR
  DIRECTOR
  PRODUCER
  WRITER
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum Visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum InterviewAssetType {
  VIDEO
  THUMBNAIL
  SUBTITLE
  AUDIO
}

model ActorInterview {
  id String @id @default(cuid())

  title String
  slug  String @unique

  description String? @db.Text

  videoUrl String

  thumbnailUrl String?

  durationSeconds Int?

  languageId String?

  publishedAt DateTime?

  viewsCount BigInt @default(0)

  status ContentStatus @default(DRAFT)

  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actorId String

  actor Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  movieId String?

  movie Movie? @relation(fields: [movieId], references: [id], onDelete: SetNull)

  seriesId String?

  series InterviewSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  tags   ActorInterviewTag[]
  assets InterviewAsset[]

  @@index([actorId])
  @@index([movieId])
  @@index([seriesId])
  @@index([status])
}

model InterviewTag {
  id String @id @default(cuid())

  name String @unique
  slug String @unique

  interviews ActorInterviewTag[]
}

model ActorInterviewTag {
  interviewId String
  tagId       String

  interview ActorInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  tag       InterviewTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([interviewId, tagId])
}

model InterviewAsset {
  id String @id @default(cuid())

  interviewId String

  type InterviewAssetType

  storageKey String

  playbackUrl String?

  language String?

  createdAt DateTime @default(now())

  interview ActorInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model InterviewSeries {
  id String @id @default(cuid())

  title String
  slug  String @unique

  description String?

  interviews ActorInterview[]

  createdAt DateTime @default(now())
}

model ModerationLog {
  id String @id @default(cuid())

  moderatorId String
  moderator   User   @relation("ModeratorLogs", fields: [moderatorId], references: [id])

  targetUserId String?
  targetUser   User?   @relation("TargetUserLogs", fields: [targetUserId], references: [id])

  action ModerationAction

  description String?

  ipAddress String?

  createdAt DateTime @default(now())

  @@index([moderatorId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

model Movie {
  id String @id @default(cuid())

  title String
  slug  String @unique

  shortDescription String? @db.VarChar(300)
  description      String  @db.Text

  releaseDate DateTime?

  durationSeconds Int

  maturityRatingId String
  languageId       String

  imdbRating      Float?
  popularityScore Float? @default(0)

  status ContentStatus @default(DRAFT)

  visibility Visibility @default(PRIVATE)

  featured Boolean @default(false)

  viewsCount BigInt @default(0)

  publishedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  maturityRating MaturityRating @relation(fields: [maturityRatingId], references: [id])

  language Language @relation(fields: [languageId], references: [id])

  genres MovieGenre[]
  cast   MovieCast[]

  assets MediaAsset[]

  trailers Trailer[]

  keywords MovieKeyword[]

  watchHistory WatchHistory[]
  watchlist    Watchlist[]
  interviews   ActorInterview[]

  @@index([slug])
  @@index([status])
  @@index([featured])
  @@index([releaseDate])
}

model MediaAsset {
  id String @id @default(cuid())

  movieId String

  type MediaAssetType

  storageKey  String
  playbackUrl String?

  mimeType String?

  width  Int?
  height Int?

  duration Int?

  sizeInBytes BigInt?

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([movieId])
  @@index([type])
}

model MovieCast {
  movieId String
  actorId String

  characterName String?

  roleType CastRoleType @default(ACTOR)

  displayOrder Int?

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  actor Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@id([movieId, actorId])
  @@index([actorId])
}

model Genre {
  id String @id @default(cuid())

  name String
  slug String @unique

  movies MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model Language {
  id String @id @default(cuid())

  name String
  code String @unique

  movies Movie[]
}

model MaturityRating {
  id String @id @default(cuid())

  code String @unique

  description String?

  movies Movie[]
}

model Trailer {
  id String @id @default(cuid())

  movieId String

  title String?

  playbackUrl String

  thumbnailUrl String?

  createdAt DateTime @default(now())

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model Keyword {
  id String @id @default(cuid())

  name String @unique

  movies MovieKeyword[]
}

model MovieKeyword {
  movieId   String
  keywordId String

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@id([movieId, keywordId])
}

model UserProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String?

  avatar String?
  banner String?

  bio String?

  country  String?
  language String?

  // Social links
  facebookUrl String?
  youtubeUrl  String?
  discordUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id String @id @default(cuid())

  name        String  @unique
  description String?

  permissions RolePermission[]
  users       UserRoleMapping[]
}

model Permission {
  id String @id @default(cuid())

  key         String  @unique
  description String?

  roles RolePermission[]
}

model RolePermission {
  id String @id @default(cuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRoleMapping {
  id String @id @default(cuid())

  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// subscriber.prisma
// Model: Subscriber
// Tracks newsletter and marketing mailing list signups.
// ============================================================

model Subscriber {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?

  // Linking to User if they decide to register later
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  status SubscriberStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([userId])
}

model Subscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   SubscriptionType
  status SubscriptionStatus

  price    Decimal @db.Decimal(10, 2)
  currency String  @default("BDT")

  startDate   DateTime
  endDate     DateTime
  cancelledAt DateTime?

  payments PaymentHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([endDate])
}

model PaymentHistory {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  provider PaymentProvider

  transactionId String @unique

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("BDT")

  status PaymentStatus

  paymentMethod String?

  paidAt        DateTime?
  failureReason String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([subscriptionId])
  @@index([transactionId])
  @@index([status])
}

model WatchHistory {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  movieId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)

  progressSeconds Int     @default(0)
  completed       Boolean @default(false)

  lastWatchedAt DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([userId, movieId])
  @@index([userId])
  @@index([movieId])
}

model Watchlist {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  movieId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, movieId])
  @@index([userId])
  @@index([movieId])
}
